    "styleDefinitionBrief": "Modern SaaS dashboard with premium calm depth, crisp hierarchy, indigo-led accents, glass-soft surfaces, and focused productivity cues.",
    "designRead": "Task management SaaS / team leads and contributors / premium calm operational clarity / medium-high density / avoid generic blue card wall",
    "designDials": {
      "layoutVariance": 2,
      "motionIntensity": 2,
      "visualDensity": 4
    },
    "styleContinuityAnchors": {
      "colorSystem": "One indigo primary hue only for CTA, active states, emphasis chips, and key data highlights. Neutrals stay cool and quiet; success, warning, error, and info colors appear only for real status meaning.",
      "shapeSystem": "Restrained radii with 4px, 8px, and 14px usage. Panels feel crisp and premium, never bubbly or oversized.",
      "typographySystem": "Inter-led sans-serif system with tight title tracking, strong numeric emphasis, compact uppercase labels, and highly readable body copy.",
      "spacingSystem": "Comfortable enterprise spacing with roomy panel padding, compact list rows, and clear separation between analytics, work queues, and supporting utilities.",
      "componentLanguage": "Glass-soft panels, floating command bar, compact chips, premium segmented controls, and precise metric cards with visible hierarchy.",
      "surfaceAndDepth": "Static surfaces rely on borders and contrast first. Shadows remain extremely soft; deeper elevation is reserved for floating bars or focused cards only.",
      "imageryAndIconography": "No decorative photography. The visual personality comes from gradients, data chips, indigo glow fields, and crisp line icons.",
      "interactionTone": "Subtle polished motion only: soft lift on hover, active pill transitions, and calm highlight movement that supports productivity."
    },
    "specsConstraints": null,
    "sharedProjectShellContract": {
      "navigationShell": "Authenticated pages share a floating left navigation rail with a premium brand block, active pill highlight, and a quiet workspace summary card at the bottom.",
      "primaryColorSystem": "Use indigo as the single brand hue for primary CTA, active nav, selected filters, and focused metrics.",
      "typographySystem": "Inter-based title and body system with large numeric stats, compact uppercase labels, and restrained subtitles.",
      "radiusScale": "Use 4px micro corners, 8px controls, and 14px cards and panels. Do not exceed 16px on ordinary surfaces.",
      "surfaceDepthModel": "Panels use translucent white or deep navy surfaces with borders and very soft shadows; only floating bars can feel more elevated.",
      "ctaStyle": "Primary actions are filled indigo buttons with crisp corners; secondary actions are soft tinted pills with clear icon support.",
      "alignmentRules": "Use a disciplined multi-column dashboard grid, a stable toolbar rhythm, left-aligned section titles, and right-aligned utility actions."
    },
